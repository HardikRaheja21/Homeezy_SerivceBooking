# .env.example
# Copy this to .env and fill in real values.
# NEVER commit .env to git — only .env.example.

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=Homeezy
DEBUG=False
DEV_MODE=True    # Set False in staging/production

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev (Docker Compose spins up postgres automatically):
DATABASE_URL=postgresql://postgres:password@localhost:5432/homeezy
# Production (Neon):
# DATABASE_URL=postgresql://neondb_owner:<password>@<host>/neondb?sslmode=require

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM=noreply@homeezy.com

# ── SMS / OTP (Twilio) ────────────────────────────────────────────────────────
# Leave blank to disable SMS in DEV_MODE
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Payments ──────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
STRIPE_SECRET_KEY=

# ── Cloud Storage (AWS S3) ────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=homeezy-uploads
AWS_REGION=ap-south-1

# ── AI ────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Celery (background tasks) ─────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Admin Bootstrap ───────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@homeezy.com
ADMIN_PASSWORD=change-this-strong-password
PLATFORM_COMMISSION_PERCENT=15.0
